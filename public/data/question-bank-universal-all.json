[{"id":"F-core-001","text":"When working on something that genuinely interests you, you can keep your attention on it for a long stretch without your mind wandering.","category":"focus","dimensionWeights":{"F":0.82,"P":0,"S":0.12,"E":0,"R":0,"C":0,"T":0.06,"I":0,"A":0,"V":0},"informationGain":0.78,"type":"core","difficulty":"broad","tags":["focus"],"culturalContext":"universal","reverseScored":false},{"id":"F-core-002","text":"Background noise, people moving, or small interruptions usually derail your concentration completely.","category":"focus","dimensionWeights":{"F":0.8,"P":0,"S":0.14,"E":0.06,"R":0,"C":0,"T":0,"I":0,"A":0,"V":0},"informationGain":0.74,"type":"core","difficulty":"broad","tags":["focus"],"culturalContext":"universal","reverseScored":true},{"id":"F-core-003","text":"Within a few minutes of starting a focused task, you often catch yourself doing something else without planning to.","category":"focus","dimensionWeights":{"F":0.78,"P":0,"S":0,"E":0,"R":0,"C":0.1,"T":0,"I":0,"A":0.12,"V":0},"informationGain":0.72,"type":"core","difficulty":"broad","tags":["focus"],"culturalContext":"universal","reverseScored":true},{"id":"P-core-001","text":"You are comfortable spotting rules, regularities, or hidden structure behind concrete examples.","category":"pattern","dimensionWeights":{"F":0.08,"P":0.84,"S":0,"E":0,"R":0.08,"C":0,"T":0,"I":0,"A":0,"V":0},"informationGain":0.76,"type":"core","difficulty":"broad","tags":["pattern"],"culturalContext":"universal","reverseScored":false},{"id":"P-core-002","text":"Abstract diagrams or purely symbolic explanations rarely feel clear unless tied to a concrete example.","category":"pattern","dimensionWeights":{"F":0.08,"P":0.8,"S":0,"E":0,"R":0,"C":0,"T":0,"I":0,"A":0,"V":0.12},"informationGain":0.7,"type":"core","difficulty":"broad","tags":["pattern"],"culturalContext":"universal","reverseScored":true},{"id":"P-core-003","text":"You prefer instructions that list exact steps over explanations that stress the “big idea” behind them.","category":"pattern","dimensionWeights":{"F":0,"P":0.78,"S":0,"E":0,"R":0.14,"C":0,"T":0,"I":0,"A":0,"V":0.08},"informationGain":0.68,"type":"core","difficulty":"broad","tags":["pattern"],"culturalContext":"universal","reverseScored":true},{"id":"S-core-001","text":"Bright lights, strong smells, or crowded noisy spaces can quickly feel overwhelming.","category":"sensory","dimensionWeights":{"F":0.07,"P":0,"S":0.85,"E":0.08,"R":0,"C":0,"T":0,"I":0,"A":0,"V":0},"informationGain":0.8,"type":"core","difficulty":"broad","tags":["sensory"],"culturalContext":"universal","reverseScored":false},{"id":"S-core-002","text":"You hardly notice typical everyday sensory stimulation in busy shared spaces; it rarely bothers you.","category":"sensory","dimensionWeights":{"F":0.1,"P":0,"S":0.82,"E":0.08,"R":0,"C":0,"T":0,"I":0,"A":0,"V":0},"informationGain":0.73,"type":"core","difficulty":"broad","tags":["sensory"],"culturalContext":"universal","reverseScored":true},{"id":"S-core-003","text":"Loud overlapping conversations feel like neutral background; they rarely drain your energy.","category":"sensory","dimensionWeights":{"F":0.08,"P":0,"S":0.8,"E":0.12,"R":0,"C":0,"T":0,"I":0,"A":0,"V":0},"informationGain":0.7,"type":"core","difficulty":"broad","tags":["sensory"],"culturalContext":"universal","reverseScored":true},{"id":"E-core-001","text":"After several hours in lively group settings, you usually need quiet time alone to recharge.","category":"social","dimensionWeights":{"F":0.06,"P":0,"S":0.1,"E":0.84,"R":0,"C":0,"T":0,"I":0,"A":0,"V":0},"informationGain":0.77,"type":"core","difficulty":"broad","tags":["social"],"culturalContext":"universal","reverseScored":false},{"id":"E-core-002","text":"Being around many people for a long time tends to energise you rather than wear you down.","category":"social","dimensionWeights":{"F":0.1,"P":0,"S":0.08,"E":0.82,"R":0,"C":0,"T":0,"I":0,"A":0,"V":0},"informationGain":0.73,"type":"core","difficulty":"broad","tags":["social"],"culturalContext":"universal","reverseScored":true},{"id":"E-core-003","text":"You look forward to back-to-back social events on the same day and rarely feel “peopled out”.","category":"social","dimensionWeights":{"F":0.08,"P":0,"S":0,"E":0.8,"R":0.12,"C":0,"T":0,"I":0,"A":0,"V":0},"informationGain":0.71,"type":"core","difficulty":"broad","tags":["social"],"culturalContext":"universal","reverseScored":true},{"id":"R-core-001","text":"Knowing the plan in advance and having predictable routines helps you feel settled and effective.","category":"structure","dimensionWeights":{"F":0.06,"P":0,"S":0,"E":0,"R":0.84,"C":0.1,"T":0,"I":0,"A":0,"V":0},"informationGain":0.75,"type":"core","difficulty":"broad","tags":["structure"],"culturalContext":"universal","reverseScored":false},{"id":"R-core-002","text":"You are comfortable improvising when schedules change at the last minute and rarely find that stressful.","category":"structure","dimensionWeights":{"F":0.06,"P":0,"S":0,"E":0,"R":0.82,"C":0.12,"T":0,"I":0,"A":0,"V":0},"informationGain":0.72,"type":"core","difficulty":"broad","tags":["structure"],"culturalContext":"universal","reverseScored":true},{"id":"R-core-003","text":"You prefer open-ended days with few fixed commitments over days blocked into timed slots.","category":"structure","dimensionWeights":{"F":0,"P":0,"S":0,"E":0,"R":0.8,"C":0.08,"T":0.12,"I":0,"A":0,"V":0},"informationGain":0.7,"type":"core","difficulty":"broad","tags":["structure"],"culturalContext":"universal","reverseScored":true},{"id":"C-core-001","text":"When new information contradicts what you believed, you can revise your view without much inner resistance.","category":"flexibility","dimensionWeights":{"F":0,"P":0.08,"S":0,"E":0,"R":0.08,"C":0.84,"T":0,"I":0,"A":0,"V":0},"informationGain":0.76,"type":"core","difficulty":"broad","tags":["flexibility"],"culturalContext":"universal","reverseScored":false},{"id":"C-core-002","text":"Once you have decided on an answer, you find it uncomfortable to revisit it even if someone raises a good counterpoint.","category":"flexibility","dimensionWeights":{"F":0.08,"P":0,"S":0,"E":0,"R":0.1,"C":0.82,"T":0,"I":0,"A":0,"V":0},"informationGain":0.74,"type":"core","difficulty":"broad","tags":["flexibility"],"culturalContext":"universal","reverseScored":true},{"id":"C-core-003","text":"Ambiguous situations where there is no single “right” interpretation feel irritating rather than interesting.","category":"flexibility","dimensionWeights":{"F":0,"P":0.12,"S":0,"E":0,"R":0.08,"C":0.8,"T":0,"I":0,"A":0,"V":0},"informationGain":0.72,"type":"core","difficulty":"broad","tags":["flexibility"],"culturalContext":"universal","reverseScored":true},{"id":"T-core-001","text":"You usually have a clear sense of how long tasks will take and rarely lose track of time when deadlines matter.","category":"structure","dimensionWeights":{"F":0.06,"P":0,"S":0,"E":0,"R":0.1,"C":0,"T":0.84,"I":0,"A":0,"V":0},"informationGain":0.78,"type":"core","difficulty":"broad","tags":["structure"],"culturalContext":"universal","reverseScored":false},{"id":"T-core-002","text":"Hours can pass in what feels like minutes when you are absorbed; you often underestimate how much time went by.","category":"structure","dimensionWeights":{"F":0.12,"P":0,"S":0,"E":0,"R":0,"C":0,"T":0.82,"I":0,"A":0.06,"V":0},"informationGain":0.76,"type":"core","difficulty":"broad","tags":["structure"],"culturalContext":"universal","reverseScored":true},{"id":"T-core-003","text":"You frequently run late or need alarms because internal time sense is weak compared to what the clock shows.","category":"structure","dimensionWeights":{"F":0.08,"P":0,"S":0,"E":0,"R":0.12,"C":0,"T":0.8,"I":0,"A":0,"V":0},"informationGain":0.74,"type":"core","difficulty":"broad","tags":["structure"],"culturalContext":"universal","reverseScored":true},{"id":"I-core-001","text":"You notice early when you are hungry, thirsty, tired, or physically tense before it becomes severe.","category":"sensory","dimensionWeights":{"F":0,"P":0,"S":0.1,"E":0.06,"R":0,"C":0,"T":0,"I":0.84,"A":0,"V":0},"informationGain":0.77,"type":"core","difficulty":"broad","tags":["sensory"],"culturalContext":"universal","reverseScored":false},{"id":"I-core-002","text":"You are often surprised by sudden hunger, fatigue, or tension because earlier signals were easy to miss.","category":"sensory","dimensionWeights":{"F":0.1,"P":0,"S":0.08,"E":0,"R":0,"C":0,"T":0,"I":0.82,"A":0,"V":0},"informationGain":0.73,"type":"core","difficulty":"broad","tags":["sensory"],"culturalContext":"universal","reverseScored":true},{"id":"I-core-003","text":"Physical cues from your body feel vague or “far away” compared to what is happening in your surroundings.","category":"sensory","dimensionWeights":{"F":0.08,"P":0,"S":0.12,"E":0,"R":0,"C":0,"T":0,"I":0.8,"A":0,"V":0},"informationGain":0.71,"type":"core","difficulty":"broad","tags":["sensory"],"culturalContext":"universal","reverseScored":true},{"id":"A-core-001","text":"One idea often sparks many side connections, analogies, or tangents you did not plan in advance.","category":"pattern","dimensionWeights":{"F":0.06,"P":0.1,"S":0,"E":0,"R":0,"C":0,"T":0,"I":0,"A":0.84,"V":0},"informationGain":0.79,"type":"core","difficulty":"broad","tags":["pattern"],"culturalContext":"universal","reverseScored":false},{"id":"A-core-002","text":"Your thinking usually stays close to the task at hand; wide associative hops feel rare or unhelpful.","category":"pattern","dimensionWeights":{"F":0.08,"P":0,"S":0,"E":0,"R":0.1,"C":0,"T":0,"I":0,"A":0.82,"V":0},"informationGain":0.72,"type":"core","difficulty":"broad","tags":["pattern"],"culturalContext":"universal","reverseScored":true},{"id":"A-core-003","text":"You prefer sticking to a linear outline rather than following interesting but off-topic mental branches.","category":"pattern","dimensionWeights":{"F":0,"P":0.08,"S":0,"E":0,"R":0,"C":0.12,"T":0,"I":0,"A":0.8,"V":0},"informationGain":0.7,"type":"core","difficulty":"broad","tags":["pattern"],"culturalContext":"universal","reverseScored":true},{"id":"V-core-001","text":"Diagrams, maps, or mental imagery often help you understand faster than long verbal explanations alone.","category":"focus","dimensionWeights":{"F":0.06,"P":0.1,"S":0,"E":0,"R":0,"C":0,"T":0,"I":0,"A":0,"V":0.84},"informationGain":0.78,"type":"core","difficulty":"broad","tags":["focus"],"culturalContext":"universal","reverseScored":false},{"id":"V-core-002","text":"You rely mainly on spoken or written language; pictures feel optional rather than central to how you think.","category":"focus","dimensionWeights":{"F":0.12,"P":0.06,"S":0,"E":0,"R":0,"C":0,"T":0,"I":0,"A":0,"V":0.82},"informationGain":0.74,"type":"core","difficulty":"broad","tags":["focus"],"culturalContext":"universal","reverseScored":true},{"id":"V-core-003","text":"When learning something new, you prefer a clear verbal sequence over spatial or pictorial layouts.","category":"focus","dimensionWeights":{"F":0.08,"P":0,"S":0,"E":0,"R":0.12,"C":0,"T":0,"I":0,"A":0,"V":0.8},"informationGain":0.72,"type":"core","difficulty":"broad","tags":["focus"],"culturalContext":"universal","reverseScored":true},{"id":"F-ref-001","text":"You can return to a complex task after an interruption and pick up roughly where you left off.","category":"focus","dimensionWeights":{"F":0.72,"P":0,"S":0.1,"E":0,"R":0,"C":0.18,"T":0,"I":0,"A":0,"V":0},"informationGain":0.68,"type":"refinement","difficulty":"specific","tags":["focus"],"culturalContext":"universal","reverseScored":false},{"id":"F-ref-002","text":"Switching tasks frequently feels more natural than blocking long uninterrupted stretches.","category":"focus","dimensionWeights":{"F":0.7,"P":0,"S":0,"E":0,"R":0,"C":0.12,"T":0,"I":0,"A":0.18,"V":0},"informationGain":0.66,"type":"refinement","difficulty":"specific","tags":["focus"],"culturalContext":"universal","reverseScored":true},{"id":"P-ref-001","text":"You enjoy puzzles or games that reward noticing subtle patterns others overlook.","category":"pattern","dimensionWeights":{"F":0.1,"P":0.74,"S":0,"E":0,"R":0,"C":0,"T":0,"I":0,"A":0.16,"V":0},"informationGain":0.7,"type":"refinement","difficulty":"specific","tags":["pattern"],"culturalContext":"universal","reverseScored":false},{"id":"P-ref-002","text":"You rarely look for a deeper rule once a procedure “works well enough”.","category":"pattern","dimensionWeights":{"F":0,"P":0.72,"S":0,"E":0,"R":0.18,"C":0.1,"T":0,"I":0,"A":0,"V":0},"informationGain":0.65,"type":"refinement","difficulty":"specific","tags":["pattern"],"culturalContext":"universal","reverseScored":true},{"id":"S-ref-001","text":"Layered textures, perfumes, or fluorescent flicker can linger in your awareness long after exposure.","category":"sensory","dimensionWeights":{"F":0.1,"P":0,"S":0.74,"E":0,"R":0,"C":0,"T":0,"I":0.16,"A":0,"V":0},"informationGain":0.71,"type":"refinement","difficulty":"specific","tags":["sensory"],"culturalContext":"universal","reverseScored":false},{"id":"S-ref-002","text":"You can tune out sensory clutter for hours without feeling drained.","category":"sensory","dimensionWeights":{"F":0.2,"P":0,"S":0.7,"E":0.1,"R":0,"C":0,"T":0,"I":0,"A":0,"V":0},"informationGain":0.64,"type":"refinement","difficulty":"specific","tags":["sensory"],"culturalContext":"universal","reverseScored":true},{"id":"E-ref-001","text":"One-to-one conversations feel easier to sustain than free-flowing group banter.","category":"social","dimensionWeights":{"F":0.16,"P":0,"S":0.12,"E":0.72,"R":0,"C":0,"T":0,"I":0,"A":0,"V":0},"informationGain":0.67,"type":"refinement","difficulty":"specific","tags":["social"],"culturalContext":"universal","reverseScored":false},{"id":"E-ref-002","text":"You seek out large gatherings when you need a mood lift rather than when you need rest.","category":"social","dimensionWeights":{"F":0.12,"P":0,"S":0,"E":0.7,"R":0,"C":0,"T":0,"I":0,"A":0.18,"V":0},"informationGain":0.66,"type":"refinement","difficulty":"specific","tags":["social"],"culturalContext":"universal","reverseScored":true},{"id":"R-ref-001","text":"Checklists and written timelines reduce your anxiety more than verbal reminders alone.","category":"structure","dimensionWeights":{"F":0,"P":0,"S":0,"E":0,"R":0.74,"C":0,"T":0.12,"I":0,"A":0,"V":0.14},"informationGain":0.69,"type":"refinement","difficulty":"specific","tags":["structure"],"culturalContext":"universal","reverseScored":false},{"id":"R-ref-002","text":"Strict agendas feel suffocating even when they would make coordination easier.","category":"structure","dimensionWeights":{"F":0,"P":0,"S":0,"E":0.1,"R":0.72,"C":0.18,"T":0,"I":0,"A":0,"V":0},"informationGain":0.65,"type":"refinement","difficulty":"specific","tags":["structure"],"culturalContext":"universal","reverseScored":true},{"id":"C-ref-001","text":"You can hold two plausible interpretations of the same situation without forcing an immediate choice.","category":"flexibility","dimensionWeights":{"F":0,"P":0.16,"S":0,"E":0,"R":0.1,"C":0.74,"T":0,"I":0,"A":0,"V":0},"informationGain":0.7,"type":"refinement","difficulty":"specific","tags":["flexibility"],"culturalContext":"universal","reverseScored":false},{"id":"C-ref-002","text":"Changing a habit feels almost as hard as solving a technical problem from scratch.","category":"flexibility","dimensionWeights":{"F":0.1,"P":0,"S":0,"E":0,"R":0.2,"C":0.7,"T":0,"I":0,"A":0,"V":0},"informationGain":0.63,"type":"refinement","difficulty":"specific","tags":["flexibility"],"culturalContext":"universal","reverseScored":true},{"id":"T-ref-001","text":"You segment your day mentally into “before / after” anchor events rather than watching the clock constantly.","category":"structure","dimensionWeights":{"F":0.12,"P":0,"S":0,"E":0,"R":0.16,"C":0,"T":0.72,"I":0,"A":0,"V":0},"informationGain":0.66,"type":"refinement","difficulty":"specific","tags":["structure"],"culturalContext":"universal","reverseScored":false},{"id":"T-ref-002","text":"You rarely think about how long something took until someone asks you afterwards.","category":"structure","dimensionWeights":{"F":0,"P":0,"S":0,"E":0,"R":0,"C":0,"T":0.7,"I":0.18,"A":0.12,"V":0},"informationGain":0.64,"type":"refinement","difficulty":"specific","tags":["structure"],"culturalContext":"universal","reverseScored":true},{"id":"I-ref-001","text":"Noticing your breathing or heartbeat helps you gauge stress before it peaks.","category":"sensory","dimensionWeights":{"F":0.12,"P":0,"S":0.14,"E":0,"R":0,"C":0,"T":0,"I":0.74,"A":0,"V":0},"informationGain":0.68,"type":"refinement","difficulty":"specific","tags":["sensory"],"culturalContext":"universal","reverseScored":false},{"id":"I-ref-002","text":"You discover you are exhausted mainly from behaviour changes (irritability) rather than early body cues.","category":"sensory","dimensionWeights":{"F":0.12,"P":0,"S":0,"E":0.16,"R":0,"C":0,"T":0,"I":0.72,"A":0,"V":0},"informationGain":0.66,"type":"refinement","difficulty":"specific","tags":["sensory"],"culturalContext":"universal","reverseScored":true},{"id":"A-ref-001","text":"Metaphors and analogies come to mind automatically when you explain ideas to others.","category":"pattern","dimensionWeights":{"F":0,"P":0.12,"S":0,"E":0,"R":0,"C":0,"T":0,"I":0,"A":0.74,"V":0.14},"informationGain":0.71,"type":"refinement","difficulty":"specific","tags":["pattern"],"culturalContext":"universal","reverseScored":false},{"id":"A-ref-002","text":"You edit your speech to remove “too many” side threads before you say them out loud.","category":"pattern","dimensionWeights":{"F":0,"P":0,"S":0,"E":0,"R":0.18,"C":0.12,"T":0,"I":0,"A":0.7,"V":0},"informationGain":0.64,"type":"refinement","difficulty":"specific","tags":["pattern"],"culturalContext":"universal","reverseScored":true},{"id":"V-ref-001","text":"You can rotate or rearrange objects in your mind when judging whether they would fit in a space.","category":"focus","dimensionWeights":{"F":0.1,"P":0.16,"S":0,"E":0,"R":0,"C":0,"T":0,"I":0,"A":0,"V":0.74},"informationGain":0.7,"type":"refinement","difficulty":"specific","tags":["focus"],"culturalContext":"universal","reverseScored":false},{"id":"V-ref-002","text":"Written lists are your first tool; sketching or spatial models feel like an extra step.","category":"focus","dimensionWeights":{"F":0.12,"P":0,"S":0,"E":0,"R":0.16,"C":0,"T":0,"I":0,"A":0,"V":0.72},"informationGain":0.65,"type":"refinement","difficulty":"specific","tags":["focus"],"culturalContext":"universal","reverseScored":true}]