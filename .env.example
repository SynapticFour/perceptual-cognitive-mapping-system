# Copy to `.env.local` for local development. On Vercel, set variables in the project dashboard.
# Never commit `.env.local` or secrets.

# -----------------------------------------------------------------------------
# Environment mode (Vercel sets `production` automatically for Production deployments)
# -----------------------------------------------------------------------------
# NODE_ENV=development

# -----------------------------------------------------------------------------
# Canonical public URL of this deployment (metadata, absolute links, research tools)
# Production (map.synapticfour.com): use HTTPS.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://map.synapticfour.com

# -----------------------------------------------------------------------------
# Supabase (optional). If NEXT_PUBLIC_SUPABASE_URL or NEXT_PUBLIC_SUPABASE_ANON_KEY
# is missing, the app runs fully on localStorage / offline paths — no crash.
# Production (map.synapticfour.com): create the project in EU region Frankfurt (eu-central-1)
# and confirm in Dashboard → Settings → Infrastructure — must match privacy.json wording.
# https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: service role — POST /api/delete-session, ethics audit, etc. Never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only: POST /api/research/export (≥16 chars). Never expose to clients.
RESEARCH_EXPORT_API_KEY=

# Server-only: protects /research/* in middleware (≥8 chars). HttpOnly cookie + optional API header.
RESEARCH_API_KEY=

# Optional: extra pepper for the research auth cookie (defaults to a built-in string if unset).
# RESEARCH_COOKIE_SECRET=

# -----------------------------------------------------------------------------
# Debug: extra field / spatial diagnostics in cognitive pipeline (default off).
# Use `true` only when debugging; keep false in production.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PCMS_DEBUG_FIELD=false

# Legacy alias (server/build tools): same effect if NEXT_PUBLIC_* unset.
# PCMS_DEBUG_FIELD=false

# -----------------------------------------------------------------------------
# Question bank:
# - `classic` (default) — universal[+ghana] JSON packs.
# - `global_v2` — 200-item behavioral bank (`global-behavioral-v2/bank.json`).
# - `cultural_adaptive_v1` — 200-item culturally framed stems (`cultural-adaptive-v1/bank.json`), mapped to F–V routing in code.
# NEXT_PUBLIC_PCMS_QUESTION_SOURCE=classic
#
# With `cultural_adaptive_v1`, stems default by API locale (`ghana` / `gh-en` → `variants.ghana`; else `variants.global`).
# Override stem bundle: `global` | `ghana` | `west_africa` (e.g. force West Africa English phrasing on any locale).
# Also used at display time when questions include `stemVariants` (see `docs/REGIONAL-STEM-RESOLUTION.md`).
# NEXT_PUBLIC_PCMS_CULTURAL_STEM=west_africa

# Adaptive engine: `routing_coverage` (default) or `profile_diagnostic` (within-dimension mean / variance /
# reverse-group contradiction for selection; refinement may stop on session confidence or diminishing returns).
# NEXT_PUBLIC_PCMS_ADAPTIVE_MODE=profile_diagnostic
#
# Research deployments: set to `1` to force `profile_diagnostic`, hide share/SMS on results, and align with full-session exports.
# NEXT_PUBLIC_PCMS_RESEARCH_MODE=1
#
# Suppress adaptive-mode console warning in CI or local dev when you intentionally omit NEXT_PUBLIC_PCMS_ADAPTIVE_MODE:
# NEXT_PUBLIC_PCMS_SUPPRESS_ADAPTIVE_MODE_WARN=1
#
# Show the “native cultural review pending” banner for locales marked PENDING in messages (e.g. wo, tw), even in production:
# NEXT_PUBLIC_LOCALE_REVIEW_WARNINGS=true

# Research console: show amber banner on /research/* linking to docs/VALIDATION_PROTOCOL.md (honest validation status for funders).
# NEXT_PUBLIC_SHOW_VALIDATION_STATUS=true

# Results page: show “Facilitator view” toggle and optional classroom-oriented observation cards (non-clinical).
# NEXT_PUBLIC_ENABLE_FACILITATOR_VIEW=true

# ATLAS / experiential add-on: post-session self-nomination card UI (exploratory only; must not feed scoring). See docs/ATLAS.md.
# NEXT_PUBLIC_ENABLE_SELF_NOMINATION=true
#
# ATLAS: optional vignette-style item presentation (off until implemented).
# NEXT_PUBLIC_ENABLE_VIGNETTE_MODE=true
#
# ATLAS: covariance-based imputation using offline priors (content/atlas/covariance/). Off until priors exist.
# NEXT_PUBLIC_ENABLE_ATLAS_IMPUTATION=true

# -----------------------------------------------------------------------------
# Consent / ethics UI (optional; NEXT_PUBLIC_* is exposed to the browser)
# default = shorter bundled consent. qa_all_steps = every section separate (QA/screenshots).
# skip = auto-accept — only for automated tests / local dev; never for real participants.
# NEXT_PUBLIC_PCMS_CONSENT_MODE=default

# Ghana / West-Africa medical-context screen: on | off | auto (default).
# NEXT_PUBLIC_PCMS_ETHICS_GHANA_STEP=auto
# NEXT_PUBLIC_PCMS_ETHICS_REGION=

# Optional: show cohort insights entry points when set to `1`.
# NEXT_PUBLIC_PCMS_SHOW_COHORT_INSIGHTS=

# Optional: amber operator bar (cloud env + last remote write + offline queue). Set to `1` for staging / debugging only.
# NEXT_PUBLIC_PCMS_SHOW_OPERATOR_SYNC_DIAGNOSTIC=
