# Copy to `.env.local` for local development. On Vercel, set variables in the project dashboard.
# Never commit `.env.local` or secrets.

# -----------------------------------------------------------------------------
# Environment mode (Vercel sets `production` automatically for Production deployments)
# -----------------------------------------------------------------------------
# NODE_ENV=development

# -----------------------------------------------------------------------------
# Canonical public URL of this deployment (metadata, absolute links, research tools)
# Production (map.synapticfour.com): use HTTPS.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://map.synapticfour.com

# -----------------------------------------------------------------------------
# Supabase (optional). If NEXT_PUBLIC_SUPABASE_URL or NEXT_PUBLIC_SUPABASE_ANON_KEY
# is missing, the app runs fully on localStorage / offline paths — no crash.
# Production (map.synapticfour.com): create the project in EU region Frankfurt (eu-central-1)
# and confirm in Dashboard → Settings → Infrastructure — must match privacy.json wording.
# https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: service role — POST /api/delete-session, ethics audit, etc. Never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only: POST /api/research/export (≥16 chars). Never expose to clients.
RESEARCH_EXPORT_API_KEY=

# Server-only: protects /research/* in middleware (≥8 chars). HttpOnly cookie + optional API header.
RESEARCH_API_KEY=

# Optional: extra pepper for the research auth cookie (defaults to a built-in string if unset).
# RESEARCH_COOKIE_SECRET=

# -----------------------------------------------------------------------------
# Debug: extra field / spatial diagnostics in cognitive pipeline (default off).
# Use `true` only when debugging; keep false in production.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PCMS_DEBUG_FIELD=false

# Legacy alias (server/build tools): same effect if NEXT_PUBLIC_* unset.
# PCMS_DEBUG_FIELD=false

# -----------------------------------------------------------------------------
# Question bank: `classic` (default) loads universal[+ghana] JSON; `global_v2` loads the 200-item behavioral bank.
# NEXT_PUBLIC_PCMS_QUESTION_SOURCE=classic

# -----------------------------------------------------------------------------
# Consent / ethics UI (optional; NEXT_PUBLIC_* is exposed to the browser)
# default = shorter bundled consent. qa_all_steps = every section separate (QA/screenshots).
# skip = auto-accept — only for automated tests / local dev; never for real participants.
# NEXT_PUBLIC_PCMS_CONSENT_MODE=default

# Ghana / West-Africa medical-context screen: on | off | auto (default).
# NEXT_PUBLIC_PCMS_ETHICS_GHANA_STEP=auto
# NEXT_PUBLIC_PCMS_ETHICS_REGION=

# Optional: show cohort insights entry points when set to `1`.
# NEXT_PUBLIC_PCMS_SHOW_COHORT_INSIGHTS=
