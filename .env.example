# Copy to .env.local and fill in for Supabase-backed data collection (optional for local-only runs).
# https://supabase.com/dashboard/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: Supabase service role — required for POST /api/delete-session to remove remote rows (bypasses RLS). Never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only: required for POST /api/research/export (≥16 chars). Never expose to clients.
RESEARCH_EXPORT_API_KEY=

# Server-only: protects /research/* in middleware (≥8 chars). Browser login sets HttpOnly cookie; API tools may send `x-research-api-key` or `Authorization: Bearer …`.
RESEARCH_API_KEY=

# Optional: extra pepper for the research auth cookie (defaults to a built-in string if unset).
RESEARCH_COOKIE_SECRET=

# --- Consent / ethics UI (all optional; NEXT_PUBLIC_* is exposed to the browser) ---
# default = shorter bundled consent (2–3 screens). qa_all_steps = every section on its own screen (QA/screenshots).
# skip = auto-accept consent for automated tests / local dev — do not use for real participant deployments.
# NEXT_PUBLIC_PCMS_CONSENT_MODE=default

# Ghana / West-Africa medical-context screen: on | off | auto (default). auto shows it for locale `tw` or NEXT_PUBLIC_PCMS_ETHICS_REGION=ghana|west_africa.
# NEXT_PUBLIC_PCMS_ETHICS_GHANA_STEP=auto
# NEXT_PUBLIC_PCMS_ETHICS_REGION=
