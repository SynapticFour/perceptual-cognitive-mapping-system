      "S": 0.1,
      "C": 0.04
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.79,
    "reverseScored": false,
    "gh_variant": "When a choice feels heavy — at the market or in a family talk — I sense tightness, warmth, or openness in my body before the words line up."
  },
  {
    "id": "TIAV-I-02",
    "text": "I pick up early signs of hunger, thirst, or tiredness while they are still mild.",
    "dimension_weights": {
      "I": 0.84,
      "S": 0.1,
      "E": 0.06
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.77,
    "reverseScored": false
  },
  {
    "id": "TIAV-I-03",
    "text": "Other people seem to notice hunger or fatigue before I feel it clearly.",
    "dimension_weights": {
      "I": 0.82,
      "S": 0.12,
      "F": 0.06
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.74,
    "reverseScored": true
  },
  {
    "id": "TIAV-I-04",
    "text": "Signals from my body feel faint compared to what is happening around me.",
    "dimension_weights": {
      "I": 0.8,
      "S": 0.14,
      "F": 0.06
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.72,
    "reverseScored": true
  },
  {
    "id": "TIAV-I-05",
    "text": "I sense heart rate or breathing shift during excitement or stress while it is happening.",
    "dimension_weights": {
      "I": 0.74,
      "E": 0.16,
      "T": 0.1
    },
    "type": "core",
    "difficulty": "specific",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.68,
    "reverseScored": false
  },
  {
    "id": "TIAV-I-06",
    "text": "Muscle tension in shoulders, jaw, or hands is something I notice during a busy day.",
    "dimension_weights": {
      "I": 0.72,
      "S": 0.18,
      "R": 0.1
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.66,
    "reverseScored": false
  },
  {
    "id": "TIAV-I-07",
    "text": "I realise I need water or food only after a headache or irritability shows up.",
    "dimension_weights": {
      "I": 0.78,
      "R": 0.12,
      "E": 0.1
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.71,
    "reverseScored": true
  },
  {
    "id": "TIAV-I-08",
    "text": "Fullness after eating reaches my awareness quickly enough to guide portion pace.",
    "dimension_weights": {
      "I": 0.7,
      "T": 0.18,
      "S": 0.12
    },
    "type": "core",
    "difficulty": "specific",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.64,
    "reverseScored": false
  },
  {
    "id": "TIAV-I-09",
    "text": "I track small shifts in energy across the day like a weather map inside me.",
    "dimension_weights": {
      "I": 0.83,
      "T": 0.1,
      "E": 0.07
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.75,
    "reverseScored": false
  },
  {
    "id": "TIAV-I-10",
    "text": "Physical discomfort sits in the background until it suddenly demands attention.",
    "dimension_weights": {
      "I": 0.81,
      "S": 0.12,
      "F": 0.07
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.73,
    "reverseScored": true
  },
  {
    "id": "TIAV-I-11",
    "text": "I sense temperature comfort in a room soon after entering.",
    "dimension_weights": {
      "I": 0.65,
      "S": 0.22,
      "P": 0.13
    },
    "type": "core",
    "difficulty": "specific",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.59,
    "reverseScored": false
  },
  {
    "id": "TIAV-I-12",
    "text": "Butterflies or calm in the stomach show up during anticipation or relief.",
    "dimension_weights": {
      "I": 0.73,
      "E": 0.15,
      "T": 0.12
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.66,
    "reverseScored": false
  },
  {
    "id": "TIAV-I-13",
    "text": "I connect shallow breathing with stress early enough to slow down on purpose.",
    "dimension_weights": {
      "I": 0.76,
      "R": 0.14,
      "C": 0.1
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.69,
    "reverseScored": false
  },
  {
    "id": "TIAV-I-14",
    "text": "I am last to notice that the room feels too loud or too bright for my comfort.",
    "dimension_weights": {
      "I": 0.79,
      "S": 0.14,
      "E": 0.07
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.71,
    "reverseScored": true
  },
  {
    "id": "TIAV-I-15",
    "text": "I name inner states with simple words like wired, flat, or buzzing.",
    "dimension_weights": {
      "I": 0.71,
      "V": 0.18,
      "E": 0.11
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.65,
    "reverseScored": false
  },
  {
    "id": "TIAV-I-16",
    "text": "I feel sleep pressure build gradually before a sharp drop in energy hits.",
    "dimension_weights": {
      "I": 0.75,
      "T": 0.15,
      "R": 0.1
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.68,
    "reverseScored": false
  },
  {
    "id": "TIAV-I-17",
    "text": "I notice posture slipping into a slouch before discomfort spikes.",
    "dimension_weights": {
      "I": 0.69,
      "S": 0.18,
      "F": 0.13
    },
    "type": "core",
    "difficulty": "specific",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.63,
    "reverseScored": false
  },
  {
    "id": "TIAV-I-18",
    "text": "I sense rest needs during social time before irritability leaks into my tone.",
    "dimension_weights": {
      "I": 0.77,
      "E": 0.13,
      "R": 0.1
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.7,
    "reverseScored": false
  },
  {
    "id": "TIAV-I-19",
    "text": "I rely on outside cues like meal times to guess my hunger more than inner cues.",
    "dimension_weights": {
      "I": 0.8,
      "T": 0.12,
      "S": 0.08
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.72,
    "reverseScored": true,
    "gh_variant": "I rely on meal times or what others are eating to guess my hunger more than inner cues."
  },
  {
    "id": "TIAV-I-20",
    "text": "A short body scan in my mind helps me locate where stress sits.",
    "dimension_weights": {
      "I": 0.72,
      "A": 0.14,
      "V": 0.14
    },
    "type": "refinement",
    "difficulty": "specific",
    "tags": [
      "sensory"
    ],
    "culturalContext": "universal",
    "informationGain": 0.66,
    "reverseScored": false
  },
  {
    "id": "TIAV-A-01",
    "text": "While working on one thing, my mind links useful ideas from topics that seemed unrelated.",
    "dimension_weights": {
      "A": 0.86,
      "P": 0.08,
      "F": 0.06
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "pattern"
    ],
    "culturalContext": "universal",
    "informationGain": 0.8,
    "reverseScored": false,
    "gh_variant": "While doing one task — selling, studying, or fixing something — my mind links useful ideas from topics that seemed unrelated."
  },
  {
    "id": "TIAV-A-02",
    "text": "Analogies between different areas of life show up when I let my mind wander freely.",
    "dimension_weights": {
      "A": 0.84,
      "P": 0.1,
      "V": 0.06
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "pattern"
    ],
    "culturalContext": "universal",
    "informationGain": 0.78,
    "reverseScored": false
  },
  {
    "id": "TIAV-A-03",
    "text": "My thinking stays close to the task; wide hops feel rare or distracting.",
    "dimension_weights": {
      "A": 0.82,
      "F": 0.12,
      "R": 0.06
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "pattern"
    ],
    "culturalContext": "universal",
    "informationGain": 0.74,
    "reverseScored": true
  },
  {
    "id": "TIAV-A-04",
    "text": "I prefer a straight outline and skip tempting side branches.",
    "dimension_weights": {
      "A": 0.8,
      "C": 0.12,
      "P": 0.08
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "pattern"
    ],
    "culturalContext": "universal",
    "informationGain": 0.72,
    "reverseScored": true
  },
  {
    "id": "TIAV-A-05",
    "text": "A single word can pull up a chain of memories from different years.",
    "dimension_weights": {
      "A": 0.75,
      "V": 0.15,
      "T": 0.1
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "pattern"
    ],
    "culturalContext": "universal",
    "informationGain": 0.7,
    "reverseScored": false
  },
  {
    "id": "TIAV-A-06",
    "text": "I spot parallels between a story someone tells and something I read elsewhere.",
    "dimension_weights": {
      "A": 0.73,
      "V": 0.16,
      "E": 0.11
    },
    "type": "core",
    "difficulty": "specific",
    "tags": [
      "pattern"
    ],
    "culturalContext": "universal",
    "informationGain": 0.68,
    "reverseScored": false
  },
  {
    "id": "TIAV-A-07",
    "text": "Brainstorming lists grow wide fast; pruning them down is the harder part.",
    "dimension_weights": {
      "A": 0.78,
      "E": 0.12,
      "F": 0.1
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "pattern"
    ],
    "culturalContext": "universal",
    "informationGain": 0.72,
    "reverseScored": false
  },
  {
    "id": "TIAV-A-08",
    "text": "I keep meetings and lessons on one track; side topics seldom pull me off course.",
    "dimension_weights": {
      "A": 0.7,
      "R": 0.18,
      "F": 0.12
    },
    "type": "core",
    "difficulty": "specific",
    "tags": [
      "pattern"
    ],
    "culturalContext": "universal",
    "informationGain": 0.65,
    "reverseScored": true
  },
  {
    "id": "TIAV-A-09",
    "text": "Dreams or daydreams reuse symbols that connect to daytime worries.",
    "dimension_weights": {
      "A": 0.71,
      "I": 0.15,
      "T": 0.14
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "pattern"
    ],
    "culturalContext": "universal",
    "informationGain": 0.64,
    "reverseScored": false
  },
  {
    "id": "TIAV-A-10",
    "text": "I draw creative links between tools at hand when a usual approach is blocked.",
    "dimension_weights": {
      "A": 0.83,
      "C": 0.1,
      "P": 0.07
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "pattern"
    ],
    "culturalContext": "universal",
    "informationGain": 0.76,
    "reverseScored": false
  },
  {
    "id": "TIAV-A-11",
    "text": "I lose the main thread when a conversation jumps topics quickly.",
    "dimension_weights": {
      "A": 0.79,
      "F": 0.12,
      "V": 0.09
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
