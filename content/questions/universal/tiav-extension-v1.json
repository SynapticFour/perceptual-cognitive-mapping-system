[
  {
    "id": "TIAV-T-01",
    "text": "When something important is coming up, I can picture how the next few weeks might unfold.",
    "dimension_weights": {
      "T": 0.86,
      "R": 0.08,
      "F": 0.06
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.78,
    "reverseScored": false,
    "gh_variant": "When something big is coming up — a naming ceremony, exams, or travel — I can picture how the next few weeks might unfold."
  },
  {
    "id": "TIAV-T-02",
    "text": "I start preparing for deadlines while they still feel far away on the calendar.",
    "dimension_weights": {
      "T": 0.84,
      "R": 0.1,
      "P": 0.06
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.76,
    "reverseScored": false,
    "gh_variant": "I start preparing while the date still feels far away on the calendar or in family talk."
  },
  {
    "id": "TIAV-T-03",
    "text": "Hours feel short when I am absorbed; I often look at the clock and realise more time passed than it felt like.",
    "dimension_weights": {
      "T": 0.82,
      "F": 0.12,
      "A": 0.06
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.74,
    "reverseScored": true
  },
  {
    "id": "TIAV-T-04",
    "text": "I bump tasks forward until the last stretch of pressure finally gets me moving.",
    "dimension_weights": {
      "T": 0.8,
      "R": 0.12,
      "E": 0.08
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.72,
    "reverseScored": true,
    "gh_variant": "I bump tasks forward until the last stretch before market day, exams, or travel finally gets me moving."
  },
  {
    "id": "TIAV-T-05",
    "text": "I keep a rough map in my head of what belongs to which day this week.",
    "dimension_weights": {
      "T": 0.72,
      "R": 0.16,
      "C": 0.12
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.68,
    "reverseScored": false
  },
  {
    "id": "TIAV-T-06",
    "text": "I split big projects into ordered steps with rough time boxes before I begin.",
    "dimension_weights": {
      "T": 0.74,
      "P": 0.14,
      "R": 0.12
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.7,
    "reverseScored": false
  },
  {
    "id": "TIAV-T-07",
    "text": "I work in bursts; each stretch feels shorter or longer on the clock than it felt from the inside.",
    "dimension_weights": {
      "T": 0.64,
      "F": 0.2,
      "A": 0.16
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.62,
    "reverseScored": true
  },
  {
    "id": "TIAV-T-08",
    "text": "The order of small errands in a day feels flexible; sequence matters little to me.",
    "dimension_weights": {
      "T": 0.62,
      "C": 0.22,
      "E": 0.16
    },
    "type": "core",
    "difficulty": "specific",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.58,
    "reverseScored": false,
    "gh_variant": "The order of small errands before market or after school feels flexible; sequence matters little to me."
  },
  {
    "id": "TIAV-T-09",
    "text": "I notice seasonal rhythms like holidays or exam cycles shaping how I plan ahead.",
    "dimension_weights": {
      "T": 0.83,
      "R": 0.1,
      "E": 0.07
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.75,
    "reverseScored": false,
    "gh_variant": "I notice seasons, holidays, harvest talk, or exam cycles shaping how I plan ahead."
  },
  {
    "id": "TIAV-T-10",
    "text": "Long stretches of free time feel shapeless until I give them a simple frame.",
    "dimension_weights": {
      "T": 0.81,
      "I": 0.1,
      "F": 0.09
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.73,
    "reverseScored": true
  },
  {
    "id": "TIAV-T-11",
    "text": "I replay past conversations on a loose timeline to learn what to do differently next time.",
    "dimension_weights": {
      "T": 0.73,
      "A": 0.15,
      "V": 0.12
    },
    "type": "core",
    "difficulty": "specific",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.66,
    "reverseScored": false
  },
  {
    "id": "TIAV-T-12",
    "text": "I arrive close to start times and leave little spare time for traffic or queues.",
    "dimension_weights": {
      "T": 0.79,
      "R": 0.12,
      "S": 0.09
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.71,
    "reverseScored": true,
    "gh_variant": "I arrive close to start times and leave little spare time for traffic, tro-tro waits, or queues."
  },
  {
    "id": "TIAV-T-13",
    "text": "I can describe how my typical weekday flows from morning to evening.",
    "dimension_weights": {
      "T": 0.7,
      "V": 0.18,
      "R": 0.12
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.65,
    "reverseScored": false
  },
  {
    "id": "TIAV-T-14",
    "text": "I treat today and next week as about equally “present” when choosing what to worry about.",
    "dimension_weights": {
      "T": 0.65,
      "E": 0.2,
      "A": 0.15
    },
    "type": "core",
    "difficulty": "specific",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.6,
    "reverseScored": false
  },
  {
    "id": "TIAV-T-15",
    "text": "I picture where milestones sit on a calendar before saying yes to new commitments.",
    "dimension_weights": {
      "T": 0.85,
      "R": 0.09,
      "C": 0.06
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.77,
    "reverseScored": false
  },
  {
    "id": "TIAV-T-16",
    "text": "I lose track of clock time during screen time, reading, or deep hobbies.",
    "dimension_weights": {
      "T": 0.83,
      "F": 0.1,
      "A": 0.07
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.75,
    "reverseScored": true
  },
  {
    "id": "TIAV-T-17",
    "text": "I keep mental notes about what should happen before lunch versus after school or work.",
    "dimension_weights": {
      "T": 0.71,
      "R": 0.18,
      "F": 0.11
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.67,
    "reverseScored": false
  },
  {
    "id": "TIAV-T-18",
    "text": "I feel steady when there is a clear rhythm to the week even if plans change inside it.",
    "dimension_weights": {
      "T": 0.68,
      "E": 0.18,
      "R": 0.14
    },
    "type": "core",
    "difficulty": "specific",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.63,
    "reverseScored": false
  },
  {
    "id": "TIAV-T-19",
    "text": "I underestimate how long familiar tasks take almost every time.",
    "dimension_weights": {
      "T": 0.8,
      "P": 0.12,
      "F": 0.08
    },
    "type": "core",
    "difficulty": "broad",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.72,
    "reverseScored": true
  },
  {
    "id": "TIAV-T-20",
    "text": "I enjoy imagining possible futures in detail when making a big choice.",
    "dimension_weights": {
      "T": 0.77,
      "A": 0.13,
      "E": 0.1
    },
    "type": "refinement",
    "difficulty": "specific",
    "tags": [
      "structure"
    ],
    "culturalContext": "universal",
    "informationGain": 0.69,
    "reverseScored": false
  },
  {
    "id": "TIAV-I-01",
